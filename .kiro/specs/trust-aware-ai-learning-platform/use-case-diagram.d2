direction: right

# Trust-Aware AI Learning Platform - Use Case Diagram

# Actors
actors: {
  learner: {
    shape: person
    label: "Learner\n(Student)"
  }
  
  teacher: {
    shape: person
    label: "Teacher\n(Educator)"
  }
  
  admin: {
    shape: person
    label: "Administrator\n(Platform Admin)"
  }
  
  llm_provider: {
    shape: cylinder
    label: "External LLM\nProvider"
  }
}

# PHASE 1 - PROTOTYPE USE CASES
prototype_cases: {
  label: "Phase 1 - Prototype Use Cases"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  
  # Learner Use Cases - Prototype
  learner_prototype: {
    label: "Learner Use Cases (Prototype)"
    
    submit_query: {
      shape: oval
      label: "Submit Question"
    }
    
    view_explanation: {
      shape: oval
      label: "View Stepwise\nExplanation"
    }
    
    view_confidence: {
      shape: oval
      label: "View Confidence\nScore"
    }
    
    activate_challenge: {
      shape: oval
      label: "Activate Challenge\nMode"
    }
    
    activate_simplify: {
      shape: oval
      label: "Activate Simplify\nMode"
    }
    
    complete_challenge: {
      shape: oval
      label: "Complete\nChallenge"
    }
    
    verify_response: {
      shape: oval
      label: "Verify AI\nResponse"
    }
  }
  
  # System Use Cases - Prototype
  system_prototype: {
    label: "System Use Cases (Prototype)"
    
    compute_confidence: {
      shape: oval
      label: "Compute\nConfidence Score"
    }
    
    generate_challenge: {
      shape: oval
      label: "Generate\nChallenge"
    }
    
    simplify_content: {
      shape: oval
      label: "Simplify\nContent"
    }
    
    scan_content: {
      shape: oval
      label: "Scan for Harmful\nContent"
    }
    
    track_interaction: {
      shape: oval
      label: "Track\nInteraction"
    }
  }
}

# PHASE 2+ - FUTURE USE CASES
future_cases: {
  label: "Phase 2+ - Future Use Cases"
  style.stroke: "#1565C0"
  style.stroke-width: 3
  
  # Learner Use Cases - Future
  learner_future: {
    label: "Learner Use Cases (Future)"
    
    view_literacy_score: {
      shape: oval
      label: "View AI Literacy\nScore"
    }
    
    track_progress: {
      shape: oval
      label: "Track Learning\nProgress"
    }
    
    export_data: {
      shape: oval
      label: "Export Personal\nData"
    }
    
    voice_interaction: {
      shape: oval
      label: "Use Voice\nInteraction"
    }
    
    multilingual_query: {
      shape: oval
      label: "Submit Query in\nNative Language"
    }
  }
  
  # Teacher Use Cases - Future
  teacher_future: {
    label: "Teacher Use Cases (Future)"
    
    view_analytics: {
      shape: oval
      label: "View Student\nAnalytics"
    }
    
    monitor_literacy: {
      shape: oval
      label: "Monitor AI Literacy\nTrends"
    }
    
    access_reports: {
      shape: oval
      label: "Access Engagement\nReports"
    }
    
    configure_filters: {
      shape: oval
      label: "Configure Content\nFilters"
    }
  }
  
  # Administrator Use Cases - Future
  admin_future: {
    label: "Administrator Use Cases (Future)"
    
    configure_provider: {
      shape: oval
      label: "Configure AI\nProvider"
    }
    
    monitor_health: {
      shape: oval
      label: "Monitor System\nHealth"
    }
    
    review_logs: {
      shape: oval
      label: "Review Audit\nLogs"
    }
    
    manage_users: {
      shape: oval
      label: "Manage User\nAccounts"
    }
  }
  
  # System Use Cases - Future
  system_future: {
    label: "System Use Cases (Future)"
    
    compute_literacy: {
      shape: oval
      label: "Compute AI\nLiteracy Score"
    }
    
    adapt_difficulty: {
      shape: oval
      label: "Adapt Challenge\nDifficulty"
    }
    
    generate_reflection: {
      shape: oval
      label: "Generate Reflective\nPrompts"
    }
    
    edge_inference: {
      shape: oval
      label: "Run Edge\nInference"
    }
  }
}

# LLM Provider Use Cases
llm_cases: {
  label: "External LLM Provider"
  style.stroke: "#F57C00"
  style.stroke-width: 3
  
  process_request: {
    shape: oval
    label: "Process AI\nRequest"
  }
  
  return_response: {
    shape: oval
    label: "Return AI\nResponse"
  }
  
  provide_metadata: {
    shape: oval
    label: "Provide Token\nMetadata"
  }
}

# PROTOTYPE PHASE RELATIONSHIPS
# Learner -> Prototype Use Cases
actors.learner -> prototype_cases.learner_prototype.submit_query
actors.learner -> prototype_cases.learner_prototype.view_explanation
actors.learner -> prototype_cases.learner_prototype.view_confidence
actors.learner -> prototype_cases.learner_prototype.activate_challenge
actors.learner -> prototype_cases.learner_prototype.activate_simplify
actors.learner -> prototype_cases.learner_prototype.complete_challenge
actors.learner -> prototype_cases.learner_prototype.verify_response

# System -> LLM Provider (Prototype)
prototype_cases.system_prototype.compute_confidence -> llm_cases.process_request: "uses"
llm_cases.return_response -> prototype_cases.system_prototype.compute_confidence: "provides"
llm_cases.provide_metadata -> prototype_cases.system_prototype.compute_confidence: "provides"

# Use Case Dependencies (Prototype)
prototype_cases.learner_prototype.submit_query -> prototype_cases.system_prototype.compute_confidence: "<<include>>"
prototype_cases.learner_prototype.submit_query -> prototype_cases.system_prototype.scan_content: "<<include>>"
prototype_cases.learner_prototype.submit_query -> prototype_cases.system_prototype.track_interaction: "<<include>>"
prototype_cases.learner_prototype.activate_challenge -> prototype_cases.system_prototype.generate_challenge: "<<include>>"
prototype_cases.learner_prototype.activate_simplify -> prototype_cases.system_prototype.simplify_content: "<<include>>"

# FUTURE PHASE RELATIONSHIPS
# Learner -> Future Use Cases
actors.learner -> future_cases.learner_future.view_literacy_score
actors.learner -> future_cases.learner_future.track_progress
actors.learner -> future_cases.learner_future.export_data
actors.learner -> future_cases.learner_future.voice_interaction
actors.learner -> future_cases.learner_future.multilingual_query

# Teacher -> Future Use Cases
actors.teacher -> future_cases.teacher_future.view_analytics
actors.teacher -> future_cases.teacher_future.monitor_literacy
actors.teacher -> future_cases.teacher_future.access_reports
actors.teacher -> future_cases.teacher_future.configure_filters

# Administrator -> Future Use Cases
actors.admin -> future_cases.admin_future.configure_provider
actors.admin -> future_cases.admin_future.monitor_health
actors.admin -> future_cases.admin_future.review_logs
actors.admin -> future_cases.admin_future.manage_users

# Use Case Dependencies (Future)
future_cases.learner_future.view_literacy_score -> future_cases.system_future.compute_literacy: "<<include>>"
future_cases.learner_future.track_progress -> future_cases.system_future.adapt_difficulty: "<<include>>"
prototype_cases.learner_prototype.verify_response -> future_cases.system_future.compute_literacy: "<<include>>"
future_cases.system_future.compute_literacy -> future_cases.system_future.generate_reflection: "<<extend>>"

# Administrator -> LLM Provider (Future)
actors.admin -> llm_cases.process_request: "configures"

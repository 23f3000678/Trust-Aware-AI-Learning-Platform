  style.stroke-width: 3
  
  analytics_engine: {
    label: "Analytics Engine\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    event_collector: "Event Collector"
    metrics_aggregator: "Metrics Aggregator"
    anonymizer: "PII Anonymizer"
  }
  
  engagement_tracker: {
    label: "Engagement Tracker\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    

direction: down

title: {
  label: "Trust-Aware AI Learning Platform - Modular Architecture"
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# ============================================================================
# FRONTEND LAYER
# ============================================================================
frontend_layer: {
  label: "Frontend Layer"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 3
  
  web_ui: {
    label: "Web UI (React/TypeScript)\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#2E7D32"
    
    query_interface: "Query Interface"
    confidence_display: "Confidence Display"
    challenge_ui: "Challenge UI"
    simplify_toggle: "Simplify Mode Toggle"
  }
  
  mobile_app: {
    label: "Mobile App\n[FUTURE - Phase 5]"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke: "#1565C0"
    style.stroke-dash: 5
    
    voice_ui: "Voice Interface"
    offline_mode: "Offline Mode"
  }
  
  accessibility: {
    label: "Accessibility Components\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    keyboard_nav: "Keyboard Navigation"
    screen_reader: "Screen Reader Support"
    high_contrast: "High Contrast Mode"
  }
}

# ============================================================================
# API LAYER
# ============================================================================
api_layer: {
  label: "API Layer (FastAPI)"
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
  style.stroke-width: 3
  
  request_router: {
    label: "Request Router\n[PROTOTYPE]"
    shape: hexagon
    style.fill: "#4CAF50"
    
    endpoints: "REST Endpoints\n/api/query\n/api/challenge\n/api/response"
  }
  
  auth_module: {
    label: "Authentication Module\n[FUTURE - Phase 2]"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    jwt_handler: "JWT Handler"
    session_mgmt: "Session Management"
    rbac: "Role-Based Access Control"
  }
  
  rate_limiter: {
    label: "Rate Limiter\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    ip_throttle: "IP-based Throttling"
    queue_mgmt: "Request Queue"
  }
  
  validator: {
    label: "Request Validator\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    pydantic_models: "Pydantic Models"
    error_handler: "Error Handler"
  }
}

# ============================================================================
# AI PROCESSING LAYER

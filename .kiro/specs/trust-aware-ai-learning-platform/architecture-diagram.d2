    interaction_metrics: "Interaction Metrics"
  }
  
  calibration_metrics: {
    label: "Calibration Metrics\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    trust_accuracy: "Trust Calibration Accuracy"

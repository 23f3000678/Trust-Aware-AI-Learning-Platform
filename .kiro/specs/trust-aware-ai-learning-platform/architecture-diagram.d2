  style.stroke: "#7B1FA2"
  style.stroke-width: 3
  
  prompt_orchestrator: {
    label: "Prompt Orchestrator\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    prompt_templates: "Prompt Templates"
    context_builder: "Context Builder"
    response_parser: "Response Parser"
  }
  
  trust_engine: {
    label: "Trust & Confidence Engine\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    
    confidence_scorer: "Confidence Scorer"
    warning_logic: "Warning Logic (< 70%)"
    citation_extractor: "Citation Extractor"
    calibration_tracker: "Calibration Tracker"
  }
  
  challenge_engine: {
    label: "Challenge Engine\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    
    challenge_generator: "Challenge Generator"
    evaluator: "Answer Evaluator"
    hint_system: "Adaptive Hints"
    feedback_generator: "Feedback Generator"
  }
  
  simplification_engine: {
    label: "Simplification Engine\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    
    text_simplifier: "Text Simplifier"
    complexity_scorer: "Complexity Scorer"
    accuracy_validator: "Accuracy Validator"
  }
  
  governance_module: {
    label: "Governance Module\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    content_scanner: "Content Safety Scanner"
    bias_detector: "Bias Detector"
    filter_engine: "Content Filter"
    incident_logger: "Incident Logger"
  }
  
  multilingual: {
    label: "Multilingual Processor\n[FUTURE - Phase 5]"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    translator: "Translation Engine"
    lang_detector: "Language Detector"
  }
}


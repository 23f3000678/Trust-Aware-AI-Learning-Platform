    literacy_trends: "AI Literacy Trends"
    report_generator: "Report Generator"
  }
  
  admin_dashboard: {
    label: "Admin Dashboard\n[FUTURE - Phase 3]"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    system_health: "System Health Monitor"
    audit_viewer: "Audit Log Viewer"
    provider_metrics: "LLM Provider Metrics"
  }
}

# ============================================================================
# DATA LAYER
# ============================================================================
data_layer: {
  label: "Data Layer"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 3
  
  in_memory_store: {
    label: "In-Memory Store\n[PROTOTYPE - Phase 1]"
    shape: cylinder
    style.fill: "#4CAF50"
    
    interactions: "Interactions"
    challenges: "Challenges"
    responses: "Responses"
  }
  
  user_database: {
    label: "User Database\n[FUTURE - Phase 2]"
    shape: cylinder
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    user_profiles: "User Profiles"
    credentials: "Encrypted Credentials"
    preferences: "User Preferences"
  }
  
  session_store: {
    label: "Session Store\n[FUTURE - Phase 2]"
    shape: cylinder
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    active_sessions: "Active Sessions"
    learning_context: "Learning Context"
  }
  
  logs_audit: {
    label: "Logs & Audit Storage\n[PROTOTYPE]"
    shape: cylinder
    style.fill: "#4CAF50"
    
    audit_logs: "Audit Logs (AES-256)"
    incident_logs: "Incident Logs"
    analytics_events: "Analytics Events"
  }
  
  encryption: {
    label: "Encryption Layer\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    aes256: "AES-256 Encryption"
    tls13: "TLS 1.3 Transit"
  }
}

# ============================================================================
# EXTERNAL LAYER
# ============================================================================
external_layer: {
  label: "External Integration Layer"
  style.fill: "#FCE4EC"
  style.stroke: "#AD1457"
  style.stroke-width: 3
  
  llm_integration: {
    label: "LLM Integration\n[PROTOTYPE]"
    shape: rectangle
    style.fill: "#4CAF50"
    
    GROQ_connector: "GROQ Connector"
    fallback_handler: "Fallback Handler"
    cost_tracker: "Cost Tracker"
  }
  
  llm_api: {
    label: "External LLM API\n(GROQ, etc.)"
    shape: cloud
    style.fill: "#FF9800"
    
    gpt_models: "GPT Models"
    token_metadata: "Token Metadata"
  }
  
  multi_provider: {
    label: "Multi-Provider Support\n[FUTURE - Phase 3]"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    provider_abstraction: "Provider Abstraction"
    load_balancer: "Load Balancer"
  }
  
  edge_deployment: {
    label: "Edge Deployment Module\n[FUTURE - Phase 6]"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    amd_ryzen_ai: "AMD Ryzen AI"
    model_quantization: "Model Quantization (8-bit)"
    offline_sync: "Offline Sync"
    hybrid_mode: "Hybrid Cloud-Edge"
  }
  
  voice_services: {
    label: "Voice Services\n[FUTURE - Phase 5]"
    shape: cloud
    style.fill: "#90CAF9"
    style.stroke-dash: 5
    
    speech_to_text: "Speech-to-Text"
    text_to_speech: "Text-to-Speech"
  }
}

# ============================================================================
# CONNECTIONS - Frontend to API
# ============================================================================
frontend_layer.web_ui -> api_layer.request_router: "HTTPS/REST"
frontend_layer.mobile_app -> api_layer.request_router: "HTTPS/REST" {style.stroke-dash: 5}
frontend_layer.accessibility -> frontend_layer.web_ui: "enhances"

# ============================================================================
# CONNECTIONS - API Layer Internal
# ============================================================================
api_layer.request_router -> api_layer.rate_limiter: "throttle"
api_layer.request_router -> api_layer.validator: "validate"
api_layer.request_router -> api_layer.auth_module: "authenticate" {style.stroke-dash: 5}

# ============================================================================
# CONNECTIONS - API to AI Processing
# ============================================================================
api_layer.request_router -> ai_processing_layer.prompt_orchestrator: "route query"
api_layer.request_router -> ai_processing_layer.challenge_engine: "route challenge"

# ============================================================================
# CONNECTIONS - AI Processing Layer Internal
# ============================================================================
ai_processing_layer.prompt_orchestrator -> ai_processing_layer.trust_engine: "compute confidence"
ai_processing_layer.prompt_orchestrator -> ai_processing_layer.governance_module: "scan content"
ai_processing_layer.prompt_orchestrator -> ai_processing_layer.simplification_engine: "simplify" {style.stroke-dash: 3}
ai_processing_layer.prompt_orchestrator -> ai_processing_layer.multilingual: "translate" {style.stroke-dash: 5}

ai_processing_layer.challenge_engine -> ai_processing_layer.trust_engine: "uses"
ai_processing_layer.governance_module -> data_layer.logs_audit: "log incidents"

# ============================================================================
# CONNECTIONS - AI Processing to Learning Intelligence
# ============================================================================
ai_processing_layer.trust_engine -> learning_layer.ai_literacy_module: "track calibration"
ai_processing_layer.challenge_engine -> learning_layer.ai_literacy_module: "track engagement"
learning_layer.ai_literacy_module -> learning_layer.mastery_tracker: "feed patterns" {style.stroke-dash: 5}
learning_layer.mastery_tracker -> learning_layer.recommendation_engine: "inform recommendations" {style.stroke-dash: 5}

# ============================================================================
# CONNECTIONS - Learning Intelligence to Analytics
# ============================================================================
learning_layer.ai_literacy_module -> analytics_layer.analytics_engine: "send events"
learning_layer.ai_literacy_module -> analytics_layer.calibration_metrics: "update metrics"
ai_processing_layer.challenge_engine -> analytics_layer.engagement_tracker: "track completion"

# ============================================================================
# CONNECTIONS - Analytics to Dashboards
# ============================================================================
analytics_layer.analytics_engine -> analytics_layer.educator_dashboard: "aggregate data" {style.stroke-dash: 5}
analytics_layer.analytics_engine -> analytics_layer.admin_dashboard: "system metrics" {style.stroke-dash: 5}
analytics_layer.calibration_metrics -> analytics_layer.educator_dashboard: "provide insights" {style.stroke-dash: 5}

# ============================================================================
# CONNECTIONS - Analytics to Data Layer
# ============================================================================
analytics_layer.analytics_engine -> data_layer.logs_audit: "store events"
analytics_layer.engagement_tracker -> data_layer.in_memory_store: "read/write"
analytics_layer.calibration_metrics -> data_layer.in_memory_store: "read/write"

# ============================================================================
# CONNECTIONS - Data Layer Internal
# ============================================================================
data_layer.encryption -> data_layer.in_memory_store: "encrypt"
data_layer.encryption -> data_layer.user_database: "encrypt" {style.stroke-dash: 5}
data_layer.encryption -> data_layer.logs_audit: "encrypt"

api_layer.auth_module -> data_layer.user_database: "authenticate" {style.stroke-dash: 5}
api_layer.auth_module -> data_layer.session_store: "manage sessions" {style.stroke-dash: 5}

# ============================================================================
# CONNECTIONS - AI Processing to External Layer
# ============================================================================
ai_processing_layer.prompt_orchestrator -> external_layer.llm_integration: "send query"
external_layer.llm_integration -> external_layer.llm_api: "API call"
external_layer.llm_api -> external_layer.llm_integration: "response + metadata"
external_layer.llm_integration -> ai_processing_layer.trust_engine: "return response"

external_layer.multi_provider -> external_layer.llm_api: "route to provider" {style.stroke-dash: 5}
external_layer.llm_integration -> analytics_layer.admin_dashboard: "cost metrics"

# ============================================================================
# CONNECTIONS - Edge and Voice (Future)
# ============================================================================
external_layer.edge_deployment -> ai_processing_layer.prompt_orchestrator: "local inference" {style.stroke-dash: 5}
external_layer.edge_deployment -> external_layer.llm_api: "cloud fallback" {style.stroke-dash: 5}
frontend_layer.mobile_app -> external_layer.voice_services: "voice I/O" {style.stroke-dash: 5}
external_layer.voice_services -> ai_processing_layer.prompt_orchestrator: "transcribed query" {style.stroke-dash: 5}

# ============================================================================
# LEGEND
# ============================================================================
legend: {
  label: "Legend"
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  
  prototype: {
    label: "Solid Green = Phase 1 Prototype"
    shape: rectangle
    style.fill: "#4CAF50"
  }
  
  future: {
    label: "Dashed Blue = Future Phases (2-6)"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke-dash: 5
  }
  
  external: {
    label: "Orange = External Services"
    shape: rectangle
    style.fill: "#FF9800"
  }
}
